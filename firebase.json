
{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "hosting/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "apphosting": {
          "backendId": "rentpilotweb",
          "region": "asia-east1"
        }
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
