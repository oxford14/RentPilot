
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are wide open for development.
    // Secure your database before deploying to production!
    // You should implement proper authentication and authorization checks.
    // Example: match /{document=**} { allow read, write: if request.auth != null; }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
