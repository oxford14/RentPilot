rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: This rule is insecure and for development purposes only.
    // It allows anyone to read and write to your entire database.
    // You MUST secure your database before going to production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
