# PayMongo (https://dashboard.paymongo.com/developers)
PAYMONGO_SECRET_KEY=sk_test_your_secret_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin — required to activate subscriptions after PayMongo payment
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=tenanttracker-u4wuw
# Paste the entire JSON as one line:
FIREBASE_SERVICE_ACCOUNT_KEY=
# Or save the file in the project and point to it:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Resend — transactional email (reminders, tenant accounts, announcements)
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@rent-pilot.net
RESEND_FROM_NAME=Rental Pilot
